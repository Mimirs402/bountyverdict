[Unit]
Description=Monitor the exact AgentWork Flowise Taskmarket pitch
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/Projects/sandbox/bountyverdict/agent
Environment=PATH=%h/.local/share/mise/shims:/usr/local/bin:/usr/bin
ExecStart=/usr/bin/env node --experimental-strip-types scripts/taskmarket-agentwork-pitch.ts
NoNewPrivileges=yes
PrivateTmp=yes
UMask=0077
